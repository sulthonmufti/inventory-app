{
    "openapi": "3.0.0",
    "info": {
        "title": "Inventory System API",
        "description": "Dokumentasi API untuk Manajemen Katalog Produk",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Server Lokal"
        }
    ],
    "paths": {
        "/api/products": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "Mengambil daftar produk dengan filter wajib",
                "operationId": "1bfaa78d1c2c3848ab8165c5dadcad3e",
                "parameters": [
                    {
                        "name": "category",
                        "in": "query",
                        "description": "Kategori produk (contoh: Elektronik, Pakaian)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "min_price",
                        "in": "query",
                        "description": "Harga minimal",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil"
                    },
                    "422": {
                        "description": "Parameter wajib tidak diisi"
                    }
                }
            },
            "post": {
                "tags": [
                    "Products"
                ],
                "summary": "Menambah produk baru ke database",
                "operationId": "e8185e307706e2cd84bbcf5171e2f09d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "sku",
                                    "price"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Kaos Oversize"
                                    },
                                    "sku": {
                                        "type": "string",
                                        "example": "TS-001"
                                    },
                                    "price": {
                                        "type": "integer",
                                        "example": 75000
                                    },
                                    "stock": {
                                        "type": "integer",
                                        "example": 10
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Produk Berhasil Dibuat"
                    },
                    "422": {
                        "description": "Data Tidak Valid / SKU Sudah Ada"
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Products",
            "description": "Products"
        }
    ]
}